
# =============================================================================
# Public Transport Optimisation AI Agent v2
# Environment Configuration
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Open .env and fill in your actual values
#   3. Never commit .env to git — add it to .gitignore
#   4. This file (.env.example) is safe to commit — it contains no real secrets
#
# RUN MODES (selected automatically):
#   DEMO      — no API key needed, stdlib only, full structured output
#   LANGGRAPH — LangGraph installed, no API key, real graph topology
#   LIVE LLM  — OPENAI_API_KEY set, full GPT-4o optimisation reasoning
#
# OPERATIONAL DISCLAIMER:
#   All safety-critical decisions — route suspensions, emergency diversions,
#   and service cancellations — require human dispatcher approval before
#   implementation. This system provides decision support only.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM — REQUIRED FOR LIVE MODE
# -----------------------------------------------------------------------------

# Your OpenAI API key.
# Get one at: https://platform.openai.com/api-keys
# Must start with sk- to be recognised as valid.
# If missing or blank, the system runs in DEMO mode automatically.
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model for all optimisation LLM calls.
# Options:
#   gpt-4o       — best contextual reasoning for complex incident scenarios (default)
#   gpt-4o-mini  — faster and cheaper, suitable for high-frequency polling
# For production real-time use with 30-second intervals, gpt-4o-mini is cost-effective.
# Default: gpt-4o
OPENAI_MODEL=gpt-4o

# LLM temperature — low for consistent operational decisions.
# Default: 0.05
OPENAI_TEMPERATURE=0.05


# -----------------------------------------------------------------------------
# NETWORK IDENTITY — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Name of the transit authority as it appears in all optimisation reports.
# Default: MetroLink Transit Authority
NETWORK_NAME=MetroLink Transit Authority

# City of operation.
# Default: Metro City
CITY=Metro City


# -----------------------------------------------------------------------------
# REACTIVE AGENT THRESHOLDS — OPTIONAL (defaults shown)
# The agent fires an optimisation pass only when one of these is breached.
# Tune these values to match your network's operational standards.
# -----------------------------------------------------------------------------

# Vehicle delay threshold in minutes.
# Vehicles delayed beyond this trigger a delay response action.
# Default: 5.0
DELAY_THRESHOLD_MINUTES=5.0

# Vehicle occupancy threshold as a percentage of capacity.
# Vehicles above this trigger a capacity response action.
# Default: 85.0
OCCUPANCY_THRESHOLD_PERCENT=85.0

# Headway deviation threshold as a percentage.
# Headway gaps beyond this from scheduled trigger a headway response.
# Default: 20.0
HEADWAY_DEVIATION_PCT=20.0

# Target incident response time in minutes.
# Used to prioritise which incidents require immediate LLM reasoning.
# Default: 3.0
INCIDENT_RESPONSE_MINUTES=3.0

# Planning horizon in minutes — how far ahead the agent reasons.
# Default: 60
PLANNING_HORIZON_MINUTES=60

# Maximum ReAct agent iterations per optimisation pass.
# Default: 2 (reactive agent uses max 2 passes)
MAX_REACTIVE_PASSES=2


# -----------------------------------------------------------------------------
# POLLING INTERVAL — OPTIONAL (defaults shown)
# Controls how frequently the agent checks for new triggers.
# Only relevant if you run the agent in a continuous polling loop.
# -----------------------------------------------------------------------------

# Interval in seconds between polling cycles.
# 30 seconds is appropriate for MVP.
# For production streaming (Kafka/WebSocket), this is not used.
# Default: 30
POLLING_INTERVAL_SECONDS=30


# -----------------------------------------------------------------------------
# FLEET POSITIONS — OPTIONAL
# Production source for real-time vehicle positions, delays, and occupancy.
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# GTFS-RT VehiclePositions feed URL
# Most transit agencies publish a public GTFS-RT feed.
# Format: Protobuf or JSON (specify below)
# Example: https://api.your-transit.gov/gtfs-rt/vehiclepositions
GTFS_RT_VEHICLE_POSITIONS_URL=

# GTFS-RT TripUpdates feed URL — predicted arrival/departure times
# Used for headway deviation detection
# Example: https://api.your-transit.gov/gtfs-rt/tripupdates
GTFS_RT_TRIP_UPDATES_URL=

# GTFS-RT response format
# Options: protobuf, json
# Default: json
GTFS_RT_FORMAT=json

# API key for the GTFS-RT feed (if required by your agency)
GTFS_RT_API_KEY=

# GTFS-RT polling interval in seconds
# Most agencies update every 15-30 seconds
# Default: 15
GTFS_RT_POLL_INTERVAL_SECONDS=15


# -----------------------------------------------------------------------------
# PASSENGER DEMAND — OPTIONAL
# Production source for real-time passenger load data.
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# APC (Automatic Passenger Counter) API endpoint
# APC systems from Clever Devices, Luminator, or Init transmit boardings
# and alightings per stop via cellular to a central server.
# Example: https://apc.your-transit.gov/api/v1
APC_API_BASE_URL=
APC_API_KEY=

# Alternatively: GTFS-RT OccupancyStatus extension
# Some agencies publish passenger load in the TripUpdates feed.
# Set to true to read occupancy from GTFS-RT instead of APC API.
# Default: false
USE_GTFS_RT_OCCUPANCY=false


# -----------------------------------------------------------------------------
# INCIDENT DATA — OPTIONAL
# Production source for active service disruptions.
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# CAD (Computer-Aided Dispatch) system API endpoint
# CAD systems dispatch and track operational incidents in real time.
# Example: https://cad.your-transit.gov/api/incidents/active
CAD_API_BASE_URL=
CAD_API_KEY=

# GTFS-RT ServiceAlerts feed URL — structured service alerts from your agency
# Example: https://api.your-transit.gov/gtfs-rt/servicealerts
GTFS_RT_ALERTS_URL=

# Waze for Cities / HERE Incidents API — road closure and incident data
# Used to detect road closures before they affect bus routes
# Register at: https://developers.waze.com/
WAZE_API_KEY=


# -----------------------------------------------------------------------------
# TRAFFIC CONDITIONS — OPTIONAL
# Production source for real-time road congestion affecting bus routes.
# Leave blank to use simulation data.
# -----------------------------------------------------------------------------

# HERE Traffic Flow API — real-time speed data by road segment
# Register at: https://developer.here.com/
HERE_API_KEY=

# TomTom Traffic Flow API — real-time congestion and travel times
# Register at: https://developer.tomtom.com/
TOMTOM_API_KEY=

# Google Maps Platform — Roads API for route speed data
# Register at: https://developers.google.com/maps/
GOOGLE_MAPS_API_KEY=

# Preferred traffic data provider
# Options: here, tomtom, google
# Default: here
TRAFFIC_PROVIDER=here


# -----------------------------------------------------------------------------
# PASSENGER INFORMATION — OPTIONAL
# Production channels for notifying passengers of disruptions.
# Leave blank — passenger notifications are logged internally only.
# -----------------------------------------------------------------------------

# Twilio — SMS alerts to registered passengers affected by disruptions
# Register at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Firebase Cloud Messaging (FCM) — push notifications to transit mobile app
# Register at: https://console.firebase.google.com/
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# Variable Message Sign (VMS) / RTPI API — update real-time passenger
# information displays at bus stops and stations
# Provided by your city transport authority
RTPI_API_BASE_URL=
RTPI_API_KEY=

# Journey planner webhook — notify journey planner platform of disruptions
# so passengers searching routes receive updated information
JOURNEY_PLANNER_WEBHOOK_URL=
JOURNEY_PLANNER_API_KEY=


# -----------------------------------------------------------------------------
# DISPATCH AND OPERATIONS — OPTIONAL
# Production channels for dispatching operational instructions to drivers
# and depot controllers.
# Leave blank — dispatch actions are logged internally only.
# -----------------------------------------------------------------------------

# Operations Control Centre (OCC) messaging API
# Used to push recommended actions directly to the dispatcher screen
OCC_API_BASE_URL=
OCC_API_KEY=

# Driver communication system API
# Used for direct driver messaging (hold at stop, short turn, etc.)
# Provided by your on-board unit (OBU) vendor
DRIVER_COMM_API_URL=
DRIVER_COMM_API_KEY=


# -----------------------------------------------------------------------------
# BUS PRIORITY SIGNALS — OPTIONAL
# Production channel for activating transit signal priority (TSP).
# Leave blank — signal priority recommendations are logged only.
# -----------------------------------------------------------------------------

# City SCATS/SCOOT traffic signal system API
# Used to activate bus priority at signalised intersections
# Provided by city traffic signal operations centre
TRAFFIC_SIGNAL_API_URL=
TRAFFIC_SIGNAL_API_KEY=


# -----------------------------------------------------------------------------
# STATIC SCHEDULE — OPTIONAL
# Production source for the scheduled timetable (used for headway calculations
# and delay measurement against scheduled times).
# Leave blank — the system uses the route and stop definitions in settings.py.
# -----------------------------------------------------------------------------

# GTFS static feed URL — standard transit schedule format
# Most agencies publish their static GTFS feed publicly
# Example: https://transitfeeds.com/p/your-agency/gtfs.zip
GTFS_STATIC_FEED_URL=

# How often to refresh the static GTFS feed in hours.
# Schedules typically change with each timetable period.
# Default: 24
GTFS_STATIC_REFRESH_HOURS=24


# -----------------------------------------------------------------------------
# LOGGING — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------

# Log level.
# Options: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# Audit log file — records every trigger detected, action recommended,
# and dispatcher override for performance review and incident analysis.
AUDIT_LOG_FILE=

# Retain audit logs for this many days.
# Default: 365
AUDIT_LOG_RETENTION_DAYS=365
